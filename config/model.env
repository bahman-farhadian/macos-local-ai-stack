# config/model.env — model behaviour and system prompt
#
# provision.py reads this file on every start and applies the settings to
# gpt-oss:20b via Open WebUI's model config API.  Edit here and restart to
# change how the model behaves in every chat.
#
# Syntax: KEY="value"  (double quotes required for multi-line values)
# Lines starting with # are comments and are ignored.

# ---------------------------------------------------------------------------
# System prompt
#
# Injected as the model's system message before every conversation.
# {USER_PERSONA} is replaced with the value of SYSTEM_USER_PERSONA below.
# ---------------------------------------------------------------------------
SYSTEM_PROMPT="You are a precise, expert-level assistant.

Response style:
- Answer the question directly — no preamble, no summary at the end
- Use Markdown only when it adds clarity (code blocks, short lists, headers)
- No unnecessary indentation; keep lists flat
- No emoji
- Professional, concise language
- Prioritise correctness and completeness over brevity when accuracy requires it
- If you do not know something or lack enough information to answer accurately,
  say "I don't have reliable information on that" — do not guess or fabricate

{USER_PERSONA}"

# ---------------------------------------------------------------------------
# User persona
#
# Injected into {USER_PERSONA} in the system prompt above.
# Describe your role, stack, and preferences so answers are contextualised.
# ---------------------------------------------------------------------------
SYSTEM_USER_PERSONA="I am a software engineer. Tailor explanations to someone with strong technical depth."

# ---------------------------------------------------------------------------
# Model parameters
# ---------------------------------------------------------------------------

# Lower temperature = more deterministic, fewer hallucinations.
# Range: 0.0 (fully deterministic) – 2.0 (very creative).
MODEL_TEMPERATURE=0.3

# Nucleus sampling: only tokens whose cumulative probability reaches TOP_P
# are considered.  Lower = more focused.
MODEL_TOP_P=0.85

# Limit the vocabulary at each step to the top K tokens.
MODEL_TOP_K=40

# Maximum tokens to generate in a single response.
# Caps runaway hallucinations. 2048 is enough for any technical answer.
# Increase if you need very long code generation outputs.
MODEL_MAX_TOKENS=2048
