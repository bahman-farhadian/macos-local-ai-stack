# Open WebUI admin credentials
# Copy this file to .env and fill in your values before the first start.
# These create the admin account on first boot. Keep .env out of version
# control — it is already in .gitignore.

WEBUI_ADMIN_EMAIL=admin@local.example
WEBUI_ADMIN_PASSWORD=changeme
WEBUI_ADMIN_NAME=Admin

# Hostname you will type in the browser, e.g. ai.local
# setup-ssl.sh maps it to 127.0.0.1 in /etc/hosts and includes it in the TLS
# certificate. You then reach the UI at https://<LOCAL_DOMAIN>:8443
# Leave blank to use https://127.0.0.1:8443 only.
LOCAL_DOMAIN=ai.local

# Optional: Google Programmable Search Engine (leave blank to use DuckDuckGo)
# GOOGLE_PSE_API_KEY=AIzaSy...
# GOOGLE_PSE_ENGINE_ID=12345abc...

# Optional: HuggingFace token (avoids rate-limits on first-boot embedding download)
# HF_TOKEN=hf_...
